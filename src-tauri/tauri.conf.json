{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord REC",
  "version": "0.3.7",
  "identifier": "dev.micferna.discordrec",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Discord REC",
        "width": 480,
        "height": 680,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1QkYxMEFBQzU4MDlENjYKUldSbW5ZREZxaEMvRmVUd21FNUI1bGNicHhEbVI1cGgyeWZud3E4WHpGV2lpajVKU2wyeUpIWjIK",
      "endpoints": [
        "https://github.com/micferna/discord-rec/releases/latest/download/latest.json"
      ]
    }
  }
}