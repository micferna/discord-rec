{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord REC",
  "version": "0.1.0",
  "identifier": "dev.micferna.discordrec",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Discord REC",
        "width": 480,
        "height": 680,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
